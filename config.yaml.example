models:
  # Optional: choose the active main/sub profile explicitly.
  # If omitted, the first profile is used for main and sub defaults to main.
  # active_main: "gpt-4.1"
  # active_sub: "gpt-4.1-mini"
  profiles:
    gpt-4.1:
      model: "gpt-4.1"
      api_key: "your-api-key-here"
      base_url: "https://api.openai.com/v1"
      max_tokens: 4096
      temperature: 0.0
      max_context_tokens: 128000
      # Keep provider-returned reasoning_content in history for later rounds.
      preserve_reasoning_content: true
      # For stricter gateways, inject an empty reasoning_content on assistant tool-call
      # messages if a previous round/history entry is missing it.
      backfill_reasoning_content_for_tool_calls: false

    gpt-4.1-mini:
      model: "gpt-4.1-mini"
      api_key: "your-api-key-here"
      base_url: "https://api.openai.com/v1"
      max_tokens: 4096
      temperature: 0.0
      max_context_tokens: 128000
      preserve_reasoning_content: true
      backfill_reasoning_content_for_tool_calls: false

    # Example DeepSeek reasoning profile for tool-calling workloads.
    deepseek-v4-pro:
      model: "deepseek-v4-pro"
      api_key: "your-deepseek-api-key-here"
      base_url: "https://api.deepseek.com"
      max_tokens: 8192
      temperature: 0.0
      max_context_tokens: 128000
      preserve_reasoning_content: true
      backfill_reasoning_content_for_tool_calls: false
      thinking_enabled: true
      reasoning_effort: "high"
      reasoning_replay_mode: "tool_calls"

modes:
  active: "coder"
  profiles:
    planner:
      description: "Planning-first mode; keep implementation changes minimal unless asked."
      tools: ["read_file", "glob", "grep"]
      prompt_append: "Focus on architecture, trade-offs, and actionable implementation plans."
      allowed_subagent_modes: ["explore"]

approval:
  default_mode: "require_approval"
  rules:
    - tool_name: "read_file"
      action: "allow"
    - tool_name: "glob"
      action: "allow"
    - tool_name: "grep"
      action: "allow"
    - tool_name: "write_file"
      action: "require_approval"
    - tool_name: "edit_file"
      action: "require_approval"
    - tool_name: "shell"
      action: "require_approval"
    - tool_name: "agent"
      action: "require_approval"
    - tool_source: "mcp"
      action: "require_approval"

# Optional user/workspace-level system prompt injection.
# prompt:
#   system_append: |
#     Always answer in Chinese unless explicitly requested otherwise.
#     Keep responses concise and actionable.

# Optional context compression settings. Omit to use defaults.
# context:
#   # Number of recent tool calls to protect from snipping.
#   snip_keep_recent_tools: 5
#   # Min content length (chars) to trigger tool output snip.
#   snip_threshold_chars: 1500
#   # Min line count to trigger tool output snip.
#   snip_min_lines: 6
#   # Number of recent user turns to protect during LLM summarize.
#   summarize_keep_recent_turns: 5

# Optional output/session/history settings. Omit to use defaults.
# tool_output:
#   max_chars: 12000
#   max_lines: 120
#   store_full_output: true
#   # store_dir: ".rcoder/tool-outputs"
#
# session:
#   auto_save: true
#   # dir: ".rcoder/sessions"
#
# Optional remote relay settings.
# Use `rcoder --server` to start host mode; the service will listen exactly on
# the configured relay_bind address.
# remote_exec:
#   enabled: true
#   host_mode: true
#   relay_bind: "127.0.0.1:8765"
#   bootstrap_access_secret: "replace-with-a-long-random-secret"
#   bootstrap_token_ttl_sec: 120
#   peer_token_ttl_sec: 3600
#   heartbeat_interval_sec: 10
#   heartbeat_timeout_sec: 30
#   default_tool_timeout_sec: 30
#   shell_timeout_sec: 120
#
# cli:
#   # history_file: "~/.rcoder/history"

skills:
  enabled: true
  scan_project: true
  scan_user: true
  disabled: []

# Optional MCP server examples.
